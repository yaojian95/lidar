{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Windows (vcpkg + Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "D:/vcpkg-master/vcpkg-master/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release (vcpkg + Ninja)",
      "inherits": "windows-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-build",
      "displayName": "Build Windows (vcpkg + Ninja)",
      "configurePreset": "windows-vcpkg",
      "jobs": 2
    },
    {
      "name": "windows-release-build",
      "displayName": "Build Windows Release",
      "configurePreset": "windows-release"
    }
  ]
}